{
  "manifest_version": 3,
  "name": "Kyomiru — Crunchyroll Sync",
  "version": "0.1.0",
  "description": "Sync your Crunchyroll watch history to your Kyomiru instance via your live browser session.",
  "permissions": ["storage", "webRequest"],
  "host_permissions": [
    "*://*.crunchyroll.com/*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Kyomiru sync"
  }
}
